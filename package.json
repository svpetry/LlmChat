{
    "name": "llm-chat",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently -n server,client -c blue,green \"tsx watch src/server/index.ts\" \"vite\"",
        "build": "vite build",
        "start": "tsx src/server/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,html}\""
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@mui/icons-material": "^7.1.0",
        "@mui/material": "^7.1.0",
        "@tanstack/react-query": "^5.76.0",
        "express": "^4.21.2",
        "jotai": "^2.12.5",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "sql.js": "^1.14.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^9.26.0",
        "@types/express": "^4.17.21",
        "@types/node": "^22.15.0",
        "@types/react": "^19.1.3",
        "@types/react-dom": "^19.1.3",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-react": "^4.4.1",
        "concurrently": "^9.1.2",
        "eslint": "^9.26.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.0",
        "vite": "^6.3.5",
        "vitest": "^4.1.5"
    }
}
